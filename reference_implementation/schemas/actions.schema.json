{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constitutional Action Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp_utc",
    "action_type",
    "reason_code",
    "profile_version",
    "witness"
  ],
  "properties": {
    "event_id": {"type": "integer"},
    "timestamp_utc": {"type": "string"},
    "action_type": {"type": "string", "enum": ["ACCEPT", "HOLD", "REFUSE", "ESCALATE", "TRANSFER", "RE_DESCRIBE"]},
    "reason_code": {"type": "string"},
    "profile_version": {"type": "string"},
    "witness": {
      "type": "object",
      "required": ["summary"],
      "properties": {"summary": {"type": "string"}},
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
